#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <34>;
        rows = <1>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)    RC(0,21) RC(0,20) RC(0,19) RC(0,18) RC(0,17)
            RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)    RC(0,26) RC(0,25) RC(0,24) RC(0,23) RC(0,22)
            RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)   RC(0,31) RC(0,30) RC(0,29) RC(0,28) RC(0,27)
                                        RC(0,15) RC(0,16)   RC(0,33) RC(0,32)
        >;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;
        keys
            = <&key_physical_attrs 100 100   0  17   0   0   0>
            , <&key_physical_attrs 100 100 100   5   0   0   0>
            , <&key_physical_attrs 100 100 200   0   0   0   0>
            , <&key_physical_attrs 100 100 300   5   0   0   0>
            , <&key_physical_attrs 100 100 400  12   0   0   0>
            , <&key_physical_attrs 100 100   0 117   0   0   0>
            , <&key_physical_attrs 100 100 100 105   0   0   0>
            , <&key_physical_attrs 100 100 200 100   0   0   0>
            , <&key_physical_attrs 100 100 300 105   0   0   0>
            , <&key_physical_attrs 100 100 400 112   0   0   0>
            , <&key_physical_attrs 100 100   0 217   0   0   0>
            , <&key_physical_attrs 100 100 100 205   0   0   0>
            , <&key_physical_attrs 100 100 200 200   0   0   0>
            , <&key_physical_attrs 100 100 300 205   0   0   0>
            , <&key_physical_attrs 100 100 400 212   0   0   0>
            , <&key_physical_attrs 100 100 300 300   0   0   0>
            , <&key_physical_attrs 100 100 400 300   0   0   0>
            , <&key_physical_attrs 100 100 650  12   0   0   0>
            , <&key_physical_attrs 100 100 750   5   0   0   0>
            , <&key_physical_attrs 100 100 850   0   0   0   0>
            , <&key_physical_attrs 100 100 950   5   0   0   0>
            , <&key_physical_attrs 100 100 1050 17   0   0   0>
            , <&key_physical_attrs 100 100 650 112   0   0   0>
            , <&key_physical_attrs 100 100 750 105   0   0   0>
            , <&key_physical_attrs 100 100 850 100   0   0   0>
            , <&key_physical_attrs 100 100 950 105   0   0   0>
            , <&key_physical_attrs 100 100 1050 117  0   0   0>
            , <&key_physical_attrs 100 100 650 212   0   0   0>
            , <&key_physical_attrs 100 100 750 205   0   0   0>
            , <&key_physical_attrs 100 100 850 200   0   0   0>
            , <&key_physical_attrs 100 100 950 205   0   0   0>
            , <&key_physical_attrs 100 100 1050 217  0   0   0>
            , <&key_physical_attrs 100 100 650 300   0   0   0>
            , <&key_physical_attrs 100 100 750 300   0   0   0>
            ;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
    };
};
